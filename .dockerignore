# Node modules
node_modules/
worker/node_modules/

# Build artifacts. The native addon + server bundle are produced inside the image
# (src/ is intentionally NOT ignored — the builder compiles the addon from the
# libopus submodule in-container, since a host .node can't run on Linux).
# The WASM artifacts are architecture-independent, so they are built on the host/CI
# (build:wasm) and copied in — building them in-container would require Emscripten
# under QEMU emulation (emscripten/emsdk is amd64-only), which is far too slow.
build/
dist/
!dist/opus-decoder.cjs
!dist/opus-decoder.wasm
!dist/opus-encoder.cjs
!dist/opus-encoder.wasm
dist-node/

# Development files
.dev.vars
*.log

# Git
.git/
.gitignore

# IDE
.idea/
.vscode/
*.swp
*.swo

# Documentation
*.md
!README.md

# Tests
test/
*.test.ts
*.spec.ts

# Cloudflare specific
wrangler.jsonc
wrangler-container.jsonc
worker/

# CI/CD
.github/
